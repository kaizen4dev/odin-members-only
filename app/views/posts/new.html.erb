<h1>New Post</h1>

<%= form_with model: @post do |form| %>
  <% @post.errors.full_messages.each do |message| %>
    <div class="error"> <%= message %> </div>
  <% end %>

  <%= form.label :title %>
  <br>
  <%= form.text_field :title %>
  <br>

  <%= form.label :body %>
  <br>
  <%= form.text_field :body %>
  <br>

  <%= form.submit %>
<% end %>
